{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "paths": {
      "@server/*": ["./server/*"],
      "@src/*": ["./src/*"]
    }
  },
  "include": ["server/**/*.ts", "src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
