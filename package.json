{
  "name": "tutor",
  "version": "1.0.0",
  "type": "module",
  "author": "Ross Miller <rossnmiller@gmail.com> (http://rossmiller.dev/)",
  "main": "dist-electron/main.js",
  "description": "AI-generated adaptive learning books",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "vite",
    "electron:build": "vite build && electron-builder",
    "electron:preview": "vite build && electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ server/ electron/ lib/",
    "lint:fix": "eslint --fix src/ server/ electron/ lib/",
    "release": "scripts/release.sh"
  },
  "license": "GPL-3.0",
  "packageManager": "pnpm@10.30.1",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@evilmartians/lefthook": "^2.1.3",
    "@tailwindcss/vite": "^4.2.1",
    "@types/culori": "^4.0.1",
    "@types/diff": "^8.0.0",
    "@types/hast": "^3.0.4",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "40.8.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-plugin-electron": "0.29.0",
    "vite-plugin-electron-renderer": "0.14.6",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/openai": "^3.0.41",
    "@base-ui/react": "^1.2.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/merge-json-schemas": "^0.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "@hookform/resolvers": "^5.2.2",
    "@reduxjs/toolkit": "^2.11.2",
    "ai": "^6.0.116",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "culori": "^4.0.2",
    "diff": "^8.0.3",
    "epub-gen-memory": "^1.1.2",
    "fastify": "^5.8.1",
    "highlight.js": "^11.11.1",
    "json-schema-ref-resolver": "^3.0.0",
    "katex": "^0.16.37",
    "lucide-react": "^0.577.0",
    "mermaid": "^11.13.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.2.0",
    "redux-persist": "^6.0.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shadcn": "^4.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "build": {
    "appId": "com.tutor.app",
    "productName": "Tutor",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "target": "dmg",
      "notarize": true,
      "icon": "assets/appicon.icon",
      "extraResources": [
        {
          "from": "assets/icon.png",
          "to": "assets/icon.png"
        }
      ]
    },
    "linux": {
      "target": "AppImage"
    },
    "win": {
      "target": "nsis"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@evilmartians/lefthook",
      "electron",
      "esbuild"
    ]
  }
}
